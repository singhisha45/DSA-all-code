int printArray(int arr[], int size){
    for(int i =0; i<size; i++) {
        cout << arr[i] << " ";
    }
    return 0;
}

int main(){
 int n;

 cin>> n;
 int arr[n];
 for(int i =0; i<n; i++) {
        cin >> arr[i] ;
    }
    cout<< "Before swap" << endl;
    printArray(arr,n);
    cout<< endl;
    cout<< "After swap" << endl;
    swapElement(arr,0,n-1);
    printArray(arr,n);
    cout<< endl;
  
 return 0;
 } 
