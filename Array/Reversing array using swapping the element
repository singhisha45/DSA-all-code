#include <iostream>
using namespace std;

int swapElement(int arr[], int start, int end){
    int temp;
    while(start<=end){
        temp=arr[start];
        arr[start]=arr[end];
        arr[end]=temp;
        start++;
        end--;
    }
    return 0;
}
